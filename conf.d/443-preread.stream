map $ssl_preread_server_name $http_backend {

    # SNI 分流，实现443端口转发到指定域名
    # www.test.com test_backend;
    default local_website;
    
}

# upstream test_backend {
#     server 1.1.1.1:443;
# }

# 本地网站
upstream local_website {
    server 127.0.0.1:8443;
}

server {

    listen 443;
    ssl_preread on; 
    proxy_pass $http_backend;
    proxy_connect_timeout 5s;
    proxy_timeout 1h;
    tcp_nodelay on;
}